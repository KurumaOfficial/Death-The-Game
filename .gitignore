# =============================================================================
# Death — .gitignore
# Внутренний namespace кода: WeTTeA. Игроку видим: Death.
# =============================================================================

# -----------------------------------------------------------------------------
# Gradle / Java сборка
# -----------------------------------------------------------------------------
.gradle/
build/
!gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/
out/
bin/
*.class
*.jar
!gradle/wrapper/gradle-wrapper.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*

# -----------------------------------------------------------------------------
# IntelliJ IDEA / Android Studio / Eclipse / VS Code
# -----------------------------------------------------------------------------
.idea/
*.iml
*.ipr
*.iws
.classpath
.project
.settings/
.vscode/
*.code-workspace

# -----------------------------------------------------------------------------
# Android
# -----------------------------------------------------------------------------
local.properties
captures/
.externalNativeBuild/
.cxx/
*.apk
*.aab
*.ap_
*.dex
release/

# -----------------------------------------------------------------------------
# iOS / RoboVM / MobiVM / Xcode
# -----------------------------------------------------------------------------
DerivedData/
*.xcworkspace/xcuserdata/
*.xcodeproj/xcuserdata/
*.xcodeproj/project.xcworkspace/xcuserdata/
*.mode1v3
*.mode2v3
*.perspectivev3
*.pbxuser
xcuserdata/
robovm-build/
robovm-cache/
*.ipa
*.dSYM.zip
*.dSYM
Podfile.lock
Pods/

# -----------------------------------------------------------------------------
# Rust / Cargo
# -----------------------------------------------------------------------------
rust-core/target/
target/
**/*.rs.bk
Cargo.lock.bak

# -----------------------------------------------------------------------------
# Нативные артефакты сборки (упаковываются Gradle task'ами в JAR/APK/IPA)
# -----------------------------------------------------------------------------
core/src/main/resources/natives/
desktop/build/natives/
*.dll
*.so
*.dylib
*.exp
*.lib
*.pdb

# -----------------------------------------------------------------------------
# Скомпилированные SPIR-V шейдеры (компилируются glslc на этапе сборки;
# исходники .vert/.frag/.comp хранятся в git, бинарники .spv — нет)
# -----------------------------------------------------------------------------
assets/death/shaders/**/*.spv
**/build/generated/spirv/

# -----------------------------------------------------------------------------
# Логи, дампы, профилирование
# -----------------------------------------------------------------------------
logs/
*.log
*.hprof
*.jfr
*.jstack

# -----------------------------------------------------------------------------
# Локальные/пользовательские артефакты
# -----------------------------------------------------------------------------
*.swp
*.swo
*.bak
*~
.DS_Store
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Секреты, ключи (никогда не коммитим)
# -----------------------------------------------------------------------------
*.keystore
*.jks
*.p12
*.pem
*.cer
*.env
.env.*
keystore.properties
signing.properties
secrets/

# -----------------------------------------------------------------------------
# Локальные пользовательские override Gradle
# -----------------------------------------------------------------------------
gradle-local.properties
gradle/local.gradle.kts
.gradle.local/

# -----------------------------------------------------------------------------
# Devin / AI-инструменты
# -----------------------------------------------------------------------------
.devin/
.cursor/
.aider*
